@model Youdemy.Models.AdminUserCreateViewModel
@{
    ViewData["Title"] = "Yeni Kullanıcı Oluştur";
}

<div class="container" style="max-width: 720px; margin: 40px auto;">
    <div class="card shadow-sm p-4">
        <h2>Yeni Kullanıcı Oluştur</h2>
        <p class="text-muted">Admin olarak yeni öğrenci veya öğretmen hesabı oluşturabilirsiniz.</p>

        <form asp-action="CreateUser" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-select">
                    <option value="Student">Öğrenci</option>
                    <option value="Teacher">Öğretmen</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsApproved" class="form-check-input" type="checkbox" />
                <label asp-for="IsApproved" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary">Oluştur</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Geri</a>
        </form>
    </div>
</div>
