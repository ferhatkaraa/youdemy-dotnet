@model Youdemy.Models.AdminUserCreateViewModel
@{
    ViewData["Title"] = "Yeni Kullanıcı Oluştur";
}

<div class="container" style="max-width: 680px; margin: 40px auto;">
    <div class="glass-card">
        <h2 style="font-size: 28px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block; margin-bottom: 8px;">Yeni Kullanıcı Oluştur</h2>
        <p class="page-desc" style="margin-bottom: 24px;">Admin olarak yeni öğrenci veya öğretmen hesabı oluşturabilirsiniz.</p>

        <form asp-action="CreateUser" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Username" class="form-label">Kullanıcı Adı</label>
                <input asp-for="Username" class="form-control" placeholder="Örn: ahmet123" required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="Örn: ahmet@mail.com" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="En az 6 karakter giriniz..." required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Role" class="form-label">Rol</label>
                <select asp-for="Role" class="form-select" style="width: 100%; border-radius: var(--border-radius-md); border: 1px solid var(--border-color); background-color: var(--bg-input); color: var(--text-main); padding: 12px 16px; font-size: 15px;">
                    <option value="Student">Öğrenci</option>
                    <option value="Teacher">Öğretmen</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px;">
                <input asp-for="IsApproved" type="checkbox" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
                <label asp-for="IsApproved" style="font-size: 15px; color: var(--text-main); cursor: pointer;">Hesap Onaylı Olarak Oluşturulsun</label>
            </div>
            
            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn btn-primary">Oluştur</button>
                <a asp-action="Index" class="btn" style="background: rgba(148,163,184,0.15); color: var(--text-main); text-decoration: none; padding: 12px 24px; border-radius: var(--border-radius-md); font-weight: 500;">Geri</a>
            </div>
        </form>
    </div>
</div>
