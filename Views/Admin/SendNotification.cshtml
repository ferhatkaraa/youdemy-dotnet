@model Youdemy.Models.NotificationSendViewModel
@{
    ViewData["Title"] = "Bildirim Gönder";
}

<div class="container" style="max-width: 980px; margin: 40px auto;">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                <div>
                    <h2 class="mb-1">Bildirim Gönder</h2>
                    <p class="text-muted mb-0">Seçili role toplu ya da bireysel bildirim gönderin. Hedef kitleyi belirleyin ve mesajınızı hızlıca yönetin.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Kullanıcı Yönetimine Dön</a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            <form asp-action="SendNotification" method="post">
                @Html.AntiForgeryToken()

                <div class="row gy-4">
                    <div class="col-lg-4">
                        <div class="card bg-light border-0 h-100">
                            <div class="card-body">
                                <h5 class="card-title">Hedef Grup</h5>
                                <p class="text-muted">Bildirim hangi role gönderilecek?</p>
                                <select asp-for="RecipientRole" class="form-select" onchange="this.form.submit()">
                                    @if (Model.RecipientRole == Youdemy.Models.UserRole.Student)
                                    {
                                        <option value="Student" selected>Öğrenciler</option>
                                    }
                                    else
                                    {
                                        <option value="Student">Öğrenciler</option>
                                    }

                                    @if (Model.RecipientRole == Youdemy.Models.UserRole.Teacher)
                                    {
                                        <option value="Teacher" selected>Öğretmenler</option>
                                    }
                                    else
                                    {
                                        <option value="Teacher">Öğretmenler</option>
                                    }
                                </select>
                                <span asp-validation-for="RecipientRole" class="text-danger"></span>

                                <div class="mt-4">
                                    <p class="small text-muted mb-1">Seçili kullanıcı sayısı</p>
                                    <div class="badge bg-primary fs-6">@Model.AvailableRecipients.Count() kullanıcı</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title">Alıcı Seçimi</h5>
                                <p class="text-muted">Aşağıdan bireysel kullanıcı seçebilir veya boş bırakarak seçili role toplu gönderim yapabilirsiniz.</p>

                                <div class="mb-3">
                                    <label class="form-label">Alıcıları Seç</label>
                                    <select asp-for="SelectedRecipientIds" class="form-select" multiple size="8">
                                        @foreach (var user in Model.AvailableRecipients)
                                        {
                                            <option value="@user.Id">@user.Username (@user.Email)</option>
                                        }
                                    </select>
                                </div>

                                <div class="small text-muted">Seçim yapılmadığında tüm seçili role ait kullanıcılara gönderilir.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Mesaj İçeriği</h5>
                        <div class="mb-3">
                            <label asp-for="Message" class="form-label"></label>
                            <textarea asp-for="Message" class="form-control" rows="6" placeholder="Göndermek istediğiniz mesajı buraya yazın..."></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                            <div class="text-muted">Mesaj maksimum 1000 karakter olabilir.</div>
                            <div>
                                <button type="submit" class="btn btn-primary">Bildirim Gönder</button>
                                <a asp-action="Index" class="btn btn-secondary ms-2">İptal</a>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
