@model Youdemy.Models.TeacherNotificationViewModel
@{
    ViewData["Title"] = "Öğrenciler İçin Bildirim Gönder";
}

<div class="container" style="max-width: 900px; margin: 40px auto;">
    <div class="card shadow-sm p-4">
        <h2>Öğrenciler İçin Bildirim Gönder</h2>
        <p class="text-muted">Öğrencilerinize toplu veya seçili öğrencilere bireysel bildirim gönderebilirsiniz.</p>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form asp-action="SendToStudents" method="post">
            @Html.AntiForgeryToken()
            @if (Model.SelectedCourseId.HasValue && !string.IsNullOrEmpty(Model.CourseTitle))
        {
            <div class="alert alert-info">
                Bu bildirim <strong>@Model.CourseTitle</strong> kursuna kayıtlı öğrencilere gönderilecektir.
            </div>
            <input type="hidden" asp-for="SelectedCourseId" />
        }
        <div class="mb-3">
                <label asp-for="SelectedStudentIds" class="form-label">Öğrencileri Seçin</label>
                <select asp-for="SelectedStudentIds" class="form-select" multiple size="8">
                    @foreach (var student in Model.AvailableStudents)
                    {
                        <option value="@student.Id">@student.Username (@student.Email)</option>
                    }
                </select>
                <div class="form-text">Seçim yapılmazsa seçili kursun veya tüm kurslarınızın öğrencilere gönderilecektir.</div>
            </div>
            <div class="mb-3">
                <label asp-for="Message" class="form-label"></label>
                <textarea asp-for="Message" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Bildirim Gönder</button>
            <a asp-controller="Courses" asp-action="Manage" class="btn btn-secondary ms-2">Geri</a>
        </form>
    </div>
</div>
