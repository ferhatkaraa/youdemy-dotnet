<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Youdemy</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="nav-container">
            <!-- Left Group: Logo & Discover -->
            <div class="header-left">
                <a class="logo" asp-area="" asp-controller="Home" asp-action="Index">
                    Youdemy<span class="logo-dot"></span>
                </a>
                <div class="nav-divider"></div>
                <a class="nav-discover-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" 
                   asp-controller="Home" asp-action="Index">Keşfet</a>
            </div>

            <!-- Middle Group: Responsive Search Bar -->
            <form method="get" asp-controller="Home" asp-action="Index" class="header-search-form">
                <div class="header-search-wrapper">
                    <svg class="header-search-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="text" name="search" value="@ViewData["Search"]" placeholder="Kurs arayın (C#, CSS, DOM...)" class="header-search-input" autocomplete="off" />
                </div>
            </form>
            
            @await Component.InvokeAsync("HeaderNav")
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>&copy; @DateTime.Now.Year - Youdemy. Tüm hakları saklıdır.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
