@model Youdemy.Models.LessonCreateEditViewModel
@{
    ViewData["Title"] = "Dersi Düzenle";
}

<div style="max-width: 680px; margin: 40px auto;">
    <div class="glass-card">
        <div style="margin-bottom: 24px;">
            <span style="font-size: 13px; color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Kurs İçerik Düzenleyici</span>
            <h2 style="font-size: 28px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: block; margin-top: 4px;">Ders İçeriğini Düzenle</h2>
            <div style="margin-top: 12px; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 12px 16px; border-radius: 8px; font-size: 14px;">
                <span class="text-muted">Kurs:</span> <strong style="color: var(--text-main);">@Model.CourseTitle</strong>
            </div>
        </div>
        
        <form asp-controller="Lessons" asp-action="Edit" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CourseId" />
            
            <div class="form-group">
                <label asp-for="Title" class="form-label">Ders Başlığı</label>
                <input asp-for="Title" class="form-control" placeholder="Ders başlığı giriniz" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Description" class="form-label">Ders Açıklaması</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Ders hakkında kısa bir özet..." required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="VideoUrl" class="form-label">Video Kaynağı (Youtube URL / Embed Kodu)</label>
                <input asp-for="VideoUrl" class="form-control" placeholder="Örn: https://www.youtube.com/watch?v=VIDEO_ID" required />
                <span asp-validation-for="VideoUrl" class="text-danger"></span>
                <span style="font-size: 12px; color: var(--text-muted); margin-top: 6px; display: block;">
                    Desteklenen formatlar: Klasik Youtube izleme linkleri, kısa linkler (youtu.be) veya iframe gömme (embed) kodları.
                </span>
            </div>
            
            <div class="form-group" style="max-width: 200px;">
                <label asp-for="Order" class="form-label">Ders Sırası (Müfredat Sıralaması)</label>
                <input asp-for="Order" class="form-control" type="number" min="1" required />
                <span asp-validation-for="Order" class="text-danger"></span>
            </div>
            
            <div style="display: flex; gap: 16px; margin-top: 32px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px;">
                <button type="submit" class="btn btn-primary" style="flex: 1; height: 48px;">Değişiklikleri Kaydet</button>
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-secondary" style="height: 48px;">İptal</a>
            </div>
        </form>
    </div>
</div>
