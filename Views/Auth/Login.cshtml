@model Youdemy.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div style="max-width: 480px; margin: 60px auto;">
    <div class="glass-card">
        <div style="text-align: center; margin-bottom: 32px;">
            <h2 style="font-size: 32px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block;">Tekrar Hoş Geldiniz</h2>
            <p class="text-muted" style="margin-top: 8px;">Hesabınıza giriş yaparak öğrenmeye devam edin.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>
        }

        <form asp-action="Login" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-group">
                <label asp-for="Identifier" class="form-label">Kullanıcı Adı veya E-posta</label>
                <input asp-for="Identifier" class="form-control" type="text" placeholder="Kullanıcı adı veya e-posta" autocomplete="username" required />
                <span asp-validation-for="Identifier" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; height: 48px; margin-top: 12px; font-size: 16px;">Giriş Yap</button>
        </form>

        <div style="text-align: center; margin-top: 24px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
            <p class="text-muted" style="font-size: 14px;">
                Henüz bir hesabınız yok mu? 
                <a asp-action="Register" asp-route-returnUrl="@Model?.ReturnUrl" style="color: var(--primary); font-weight: 600; text-decoration: underline;">Kayıt Olun</a>
            </p>
        </div>
    </div>
</div>
