@model Youdemy.Models.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div style="max-width: 520px; margin: 60px auto;">
    <div class="glass-card">
        <div style="text-align: center; margin-bottom: 32px;">
            <h2 style="font-size: 32px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block;">Platforma Kaydolun</h2>
            <p class="text-muted" style="margin-top: 8px;">Hesabınızı oluşturarak dilediğiniz eğitimlere hemen başlayın.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>
        }

        <form asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Username" class="form-label">Kullanıcı Adı</label>
                <input asp-for="Username" class="form-control" placeholder="yazilimci_kaan" autocomplete="username" required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="isim@domain.com" autocomplete="email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Role" class="form-label">Hesap Tipi (Rolü)</label>
                <select asp-for="Role" class="form-control form-select" required>
                    <option value="@Youdemy.Models.UserRole.Student">Öğrenci (Kurslara katılabilir, ilerlemesini takip edebilir)</option>
                    <option value="@Youdemy.Models.UserRole.Teacher">Eğitmen (Kurs ve müfredat içerikleri oluşturabilir)</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
                <small class="form-text text-muted">Eğitmen hesapları admin onayına tabidir; onaylanana kadar kurs/ders ekleyemezsiniz.</small>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="En az 6 karakter" autocomplete="new-password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Şifre Tekrar</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Şifrenizi tekrar girin" autocomplete="new-password" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; height: 48px; margin-top: 12px; font-size: 16px;">Hesap Oluştur</button>
        </form>

        <div style="text-align: center; margin-top: 24px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
            <p class="text-muted" style="font-size: 14px;">
                Zaten bir hesabınız var mı? 
                <a asp-action="Login" style="color: var(--primary); font-weight: 600; text-decoration: underline;">Giriş Yapın</a>
            </p>
        </div>
    </div>
</div>
