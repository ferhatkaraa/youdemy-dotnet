@model Youdemy.Models.CourseCreateEditViewModel
@{
    ViewData["Title"] = "Kursu Düzenle";
}

<div style="max-width: 680px; margin: 40px auto;">
    <div class="glass-card">
        <h2 style="font-size: 28px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block; margin-bottom: 24px;">Eğitim Serisini Düzenle</h2>
        
        <form asp-action="Edit" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="Title" class="form-label">Kurs Başlığı</label>
                <input asp-for="Title" class="form-control" placeholder="Örn: Sıfırdan İleri Seviye C# Programlama" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Description" class="form-label">Kurs Açıklaması</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Kurs hakkında detaylı bilgi..." required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="ImageUrl" class="form-label">Kapak Görseli URL'si (İsteğe Bağlı)</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="Örn: /images/csharp.png" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>
            
            <div style="display: flex; gap: 16px; margin-top: 32px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px;">
                <button type="submit" class="btn btn-primary" style="flex: 1; height: 48px;">Değişiklikleri Kaydet</button>
                <a asp-action="Manage" class="btn btn-secondary" style="height: 48px;">Vazgeç</a>
            </div>
        </form>
    </div>
</div>
