@model IEnumerable<Youdemy.Models.StudentCourseProgressViewModel>
@{
    ViewData["Title"] = "Eğitimlerim";
}

<div class="container" style="max-width: 1100px; margin: 40px auto;">
    <div class="flex-header">
        <div>
            <h1 class="page-title">Eğitimlerim</h1>
            <p class="page-desc">Kütüphanene eklediğin kursları buradan takip et. Hangi kursu ne kadar tamamladığını ve öğrendiğin ders sayısını görebilirsin.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card" style="padding: 32px; text-align: center; color: var(--text-muted);">
            <h3>Henüz bir kursa kaydolmadın</h3>
            <p style="margin-top: 10px;">Kütüphanene yeni bir eğitim eklemek için <a asp-controller="Home" asp-action="Index">Tüm Kurslar</a> sayfasına gidebilirsin.</p>
        </div>
    }
    else
    {
        <div class="row" style="gap: 16px; margin-bottom: 24px;">
            <div class="glass-card" style="flex: 1; min-width: 220px; padding: 20px;">
                <h4 style="margin-bottom: 8px;">Toplam Kurs</h4>
                <p style="font-size: 32px; font-weight: 700; margin: 0;">@Model.Count()</p>
            </div>
            <div class="glass-card" style="flex: 1; min-width: 220px; padding: 20px;">
                <h4 style="margin-bottom: 8px;">Devam Eden Kurslar</h4>
                <p style="font-size: 32px; font-weight: 700; margin: 0;">@Model.Count(m => m.ProgressPercentage < 100)</p>
            </div>
            <div class="glass-card" style="flex: 1; min-width: 220px; padding: 20px;">
                <h4 style="margin-bottom: 8px;">Tamamlanan Kurslar</h4>
                <p style="font-size: 32px; font-weight: 700; margin: 0;">@Model.Count(m => m.ProgressPercentage == 100)</p>
            </div>
        </div>

        <div class="row" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px;">
            @foreach (var item in Model)
            {
                <div class="glass-card" style="padding: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 14px;">
                        <div>
                            <h3 style="margin: 0 0 8px;">@item.Course.Title</h3>
                            <p style="margin: 0; color: var(--text-muted);">@item.Course.Teacher?.Username tarafından</p>
                        </div>
                        <span style="background: rgba(59,130,246,0.12); color: #2563eb; padding: 6px 12px; border-radius: 20px; font-size: 13px; font-weight: 700;">
                            @item.Course.Lessons.Count ders
                        </span>
                    </div>

                    <div style="margin-bottom: 18px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px; color: var(--text-muted);">
                            <span>Tamamlanan Ders</span>
                            <span>@item.CompletedLessonsCount / @item.TotalLessonsCount</span>
                        </div>
                        <div style="background: rgba(148,163,184,0.15); border-radius: 10px; height: 12px; overflow: hidden;">
                            <div style="width: @item.ProgressPercentage%; background: linear-gradient(90deg, #22c55e, #06b6d4); height: 100%;"></div>
                        </div>
                        <div style="margin-top: 8px; font-size: 13px; color: var(--text-muted);">İlerleme: @item.ProgressPercentage %</div>
                    </div>

                    <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center; justify-content: space-between;">
                        <small style="color: var(--text-muted);">Kayıt Tarihi: @item.EnrolledAt.ToString("dd.MM.yyyy")</small>
                        <a asp-controller="Courses" asp-action="Watch" asp-route-id="@item.Course.Id" class="btn btn-primary btn-sm">Kursa Git</a>
                    </div>
                </div>
            }
        </div>
    }
</div>
