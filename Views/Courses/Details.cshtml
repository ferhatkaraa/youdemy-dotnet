@model Youdemy.Models.Course
@{
    ViewData["Title"] = Model.Title;
    var isEnrolled = (bool)ViewData["IsEnrolled"]!;
    var isTeacherOfCourse = (bool)ViewData["IsTeacherOfCourse"]!;
    var errorMessage = ViewData["ErrorMessage"] as string;
}

<div style="max-width: 960px; margin: 0 auto;">
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    <!-- Course Header Card -->
    <div class="glass-card" style="margin-bottom: 40px; padding: 40px; display: flex; gap: 40px; align-items: center; flex-wrap: wrap;">
        <div class="course-img-wrapper" style="flex: 1; min-width: 280px; max-width: 360px; height: 220px; margin-bottom: 0;">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/course-default.png" : Model.ImageUrl)" alt="@Model.Title" style="width:100%;height:100%;object-fit:cover;border-radius:8px;border:1px solid rgba(255,255,255,0.04);" />
        </div>
        
        <div style="flex: 2; min-width: 320px;">
            <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px; font-size: 14px;">
                <span class="course-teacher">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: var(--primary);">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    @Model.Teacher?.Username (Eğitmen)
                </span>
                <span style="color: var(--text-muted);">•</span>
                <span style="color: var(--text-muted);">@Model.CreatedAt.ToString("dd.MM.yyyy") tarihinde eklendi</span>
            </div>
            
            <h1 style="font-size: 36px; line-height: 1.2; margin-bottom: 16px; color: var(--text-main);">@Model.Title</h1>
            <p class="text-muted" style="font-size: 15px; line-height: 1.6; margin-bottom: 28px;">@Model.Description</p>
            
            <!-- Actions CTA depending on enrollment state -->
            <div>
                @if (isTeacherOfCourse)
                {
                    <div style="display: flex; gap: 12px;">
                        <a asp-action="Watch" asp-route-id="@Model.Id" class="btn btn-primary">Kurs Önizleme Modu</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Kursu Düzenle</a>
                        <a asp-controller="Lessons" asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-secondary" style="border-color: var(--primary);">Yeni Ders Ekle</a>
                    </div>
                }
                else if (isEnrolled)
                {
                    <a asp-action="Watch" asp-route-id="@Model.Id" class="btn btn-primary" style="padding: 14px 28px; font-size: 15px;">
                        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" style="margin-right: 4px;">
                            <path d="M8 5v14l11-7z"/>
                        </svg>
                        Eğitime Devam Et
                    </a>
                }
                else if (User.Identity?.IsAuthenticated ?? false)
                {
                    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                    if (role == Youdemy.Models.UserRole.Student.ToString())
                    {
                        <form asp-action="Enroll" asp-route-id="@Model.Id" method="post" style="display: inline-block;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary" style="padding: 14px 32px; font-size: 15px;">
                                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="margin-right: 6px;">
                                    <path d="M12 4.5v15m7.5-7.5h-15"></path>
                                </svg>
                                Bu Kursa Kaydol ve Hemen Başla
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted" style="font-weight: 500; font-size: 14px; background: rgba(255,255,255,0.03); padding: 12px 18px; border-radius: 8px; border: 1px solid var(--border-color); display: inline-block;">
                             Öğrenmek için lütfen bir öğrenci hesabı ile giriş yapın.
                        </span>
                    }
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="/Courses/Details/@Model.Id" class="btn btn-primary" style="padding: 14px 32px; font-size: 15px;">
                         Kaydolmak İçin Giriş Yapın
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Course Syllabus Schedule -->
    <div class="glass-card">
        <h2 style="font-size: 24px; margin-bottom: 24px; border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 16px;">
            Müfredat İçeriği (@Model.Lessons.Count Ders)
        </h2>
        
        @if (!Model.Lessons.Any())
        {
            <div style="text-align: center; padding: 40px 20px; color: var(--text-muted);">
                <p>Bu kursa henüz ders içeriği eklenmemiştir.</p>
                @if (isTeacherOfCourse)
                {
                    <a asp-controller="Lessons" asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-secondary btn-sm" style="margin-top: 16px;">İlk Dersi Ekle</a>
                }
            </div>
        }
        else
        {
            <div style="display: flex; flex-direction: column; gap: 16px;">
                @foreach (var lesson in Model.Lessons)
                {
                    <div class="syllabus-item @(isEnrolled || isTeacherOfCourse ? "" : "locked")" 
                         style="background: rgba(255,255,255,0.015); border: 1px solid var(--border-color); border-radius: var(--border-radius-md); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; transition: var(--transition);">
                        
                        <div style="display: flex; align-items: center; gap: 16px; flex: 1;">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: var(--primary); flex-shrink: 0;">
                                @lesson.Order
                            </div>
                            
                            <div style="display: flex; flex-direction: column;">
                                @if (isEnrolled || isTeacherOfCourse)
                                {
                                    <a asp-action="Watch" asp-route-id="@Model.Id" asp-route-lessonId="@lesson.Id" 
                                       style="font-size: 15px; font-weight: 600; color: var(--text-main); hover: text-decoration: underline;" class="syllabus-link">
                                        @lesson.Title
                                    </a>
                                }
                                else
                                {
                                    <span style="font-size: 15px; font-weight: 600; color: var(--text-muted); cursor: not-allowed; display: inline-flex; align-items: center; gap: 6px;">
                                        @lesson.Title
                                        <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24" style="color: var(--text-muted); opacity: 0.5;">
                                            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                                        </svg>
                                    </span>
                                }
                                <span class="text-muted" style="font-size: 13px; margin-top: 4px;">@lesson.Description</span>
                            </div>
                        </div>
                        
                        <!-- Teacher Syllabus Management Panel -->
                        @if (isTeacherOfCourse)
                        {
                            <div style="display: flex; gap: 8px; margin-left: 16px; flex-shrink: 0;">
                                <a asp-controller="Lessons" asp-action="Edit" asp-route-id="@lesson.Id" class="btn btn-secondary btn-sm">Düzenle</a>
                                <form asp-controller="Lessons" asp-action="Delete" asp-route-id="@lesson.Id" method="post" 
                                      style="display: inline;" onsubmit="return confirm('Bu dersi silmek istediğinizden emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
