@model Youdemy.Models.CourseCreateEditViewModel
@{
    ViewData["Title"] = "Yeni Kurs Oluştur";
}

<div style="max-width: 680px; margin: 40px auto;">
    <div class="glass-card">
        <h2 style="font-size: 28px; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block; margin-bottom: 24px;">Yeni Eğitim Serisi Oluştur</h2>
        
        <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label asp-for="Title" class="form-label">Kurs Başlığı</label>
                <input asp-for="Title" class="form-control" placeholder="Örn: Sıfırdan İleri Seviye C# Programlama" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Description" class="form-label">Kurs Açıklaması</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Kurs hakkında detaylı bilgi, kazanımlar ve hedef kitle..." required></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label class="form-label">Kurs Kapak Görseli</label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
                <input type="hidden" asp-for="ImageUrl" />
                <small class="form-text text-muted" style="display: block; margin-top: 8px;">Kursa ait kapak görseli yükleyin (PNG, JPG, WEBP). Boş bırakılırsa varsayılan görsel kullanılacaktır.</small>
            </div>
            
            <div style="display: flex; gap: 16px; margin-top: 32px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px;">
                <button type="submit" class="btn btn-primary" style="flex: 1; height: 48px;">Kursu Yayınla</button>
                <a asp-action="Manage" class="btn btn-secondary" style="height: 48px;">Vazgeç</a>
            </div>
        </form>
    </div>
</div>
