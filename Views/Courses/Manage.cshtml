@model IEnumerable<Youdemy.Models.Course>
@{
    ViewData["Title"] = "Eğitmen Paneli - Kurslarımı Yönet";
}

<div class="flex-header">
    <div>
        <h1 class="page-title">Kurs Yönetim Paneli</h1>
        <p class="page-desc">Oluşturduğunuz eğitim serilerini yönetin, yeni kurslar ekleyin ve müfredatları planlayın.</p>
        @if (ViewData["ApprovalMessage"] != null)
        {
            <div class="alert alert-warning mt-3">@ViewData["ApprovalMessage"]</div>
        }
    </div>
    <div class="btn-group">
        @if (ViewData["ApprovalMessage"] != null)
        {
            <a class="btn btn-primary disabled" aria-disabled="true" title="Öğretmen hesabınız onay bekliyor. Kurs oluşturmak için onay gereklidir.">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M12 4.5v15m7.5-7.5h-15"></path>
                </svg>
                Yeni Kurs Ekle
            </a>
        }
        else
        {
            <a asp-action="Create" class="btn btn-primary">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M12 4.5v15m7.5-7.5h-15"></path>
                </svg>
                Yeni Kurs Ekle
            </a>
        }
        <a asp-controller="Notifications" asp-action="SendToStudents" class="btn btn-secondary">Öğrencilere Bildirim Gönder</a>
    </div>
</div>

<div class="glass-card" style="padding: 24px;">
    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 48px 20px; color: var(--text-muted);">
            <svg style="width: 64px; height: 64px; fill: var(--text-muted); opacity: 0.3; margin-bottom: 16px;" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm0-4h-2v-4h2v4zm0-6h-2V7h2v2z"/>
            </svg>
            <h3>Henüz bir kurs oluşturmadınız</h3>
            <p style="margin-top: 8px;">Yukarıdaki butona tıklayarak ilk kursunuzu oluşturabilir ve hemen ders eklemeye başlayabilirsiniz!</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="glass-table">
                <thead>
                    <tr>
                        <th>Kurs Başlığı</th>
                        <th>Oluşturulma Tarihi</th>
                        <th>Ders Sayısı</th>
                        <th>Öğrenci Sayısı</th>
                        <th style="text-align: right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td style="font-weight: 600;">@course.Title</td>
                            <td style="color: var(--text-muted);">@course.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span style="background: rgba(99,102,241,0.15); color: var(--primary); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700;">
                                    @course.Lessons.Count Ders
                                </span>
                            </td>
                            <td>
                                <span style="background: rgba(16,185,129,0.14); color: #10b981; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700;">
                                    @course.Enrollments.Count Öğrenci
                                </span>
                            </td>
                            <td style="text-align: right;">
                                <div style="display: inline-flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end;">
                                    <a asp-controller="Notifications" asp-action="SendToStudents" asp-route-courseId="@course.Id" class="btn btn-secondary btn-sm">Kursa Bildirim Gönder</a>
                                    <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-secondary btn-sm" style="border-color: var(--primary); color: var(--text-main);">
                                        Yönet / Ders Ekle
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-secondary btn-sm">Düzenle</a>
                                    <form asp-action="Delete" asp-route-id="@course.Id" method="post" 
                                          style="display: inline;" onsubmit="return confirm('Bu kursu silmek istediğinizden emin misiniz? Kursla birlikte tüm ders içerikleri de kalıcı olarak silinecektir!');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
